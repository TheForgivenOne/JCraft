{
  "name": "jcraft",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "apps/*/*",
    "libs/*",
    "services/*",
    "tooling/*"
  ],
  "scripts": {
    "dev": "pnpm --parallel --filter \"./apps/*\" --filter \"./apps/*/*\" dev",
    "build": "pnpm --filter \"@jcraft/types\" build && pnpm --filter \"@jcraft/utils\" build && pnpm --filter \"@jcraft/ui\" build && pnpm --filter \"./apps/*\" --filter \"./apps/*/*\" build",
    "lint": "pnpm --recursive lint",
    "lint:fix": "pnpm --recursive lint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "rm -rf node_modules && pnpm --recursive clean",
    "convex": "npx convex",
    "audit": "pnpm audit --audit-level moderate",
    "audit:fix": "pnpm audit --fix"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^8.51.0",
    "@typescript-eslint/parser": "^8.51.0",
    "eslint": "^8.0.0",
    "eslint-config-next": "14.0.4",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "packageManager": "pnpm@8.10.2",
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-slot": "^1.2.4",
    "lucide-react": "^0.294.0",
    "tsup": "^8.0.0"
  }
}
